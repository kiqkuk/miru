#!/bin/bash

bat_path="/sys/class/power_supply/BAT0"

read -r cap < "$bat_path/capacity"
read -r stat < "$bat_path/status"

if [ "$cap" -le 20 ] && [ "$stat" != "Charging" ]; then
  if [ ! -s "${XDG_RUNTIME_DIR:-/tmp}/notify" ]; then
    notify "BATTERY LOW: $cap%" 10 &
  fi
fi

if [ "$stat" = "Charging" ]; then
    ICON="σ±ê΄"
else
    if   [ "$cap" -ge 90 ]; then ICON="σΑ¹Ι";
    elif [ "$cap" -ge 80 ]; then ICON="σΑ²²";
    elif [ "$cap" -ge 70 ]; then ICON="σΑ²¹";
    elif [ "$cap" -ge 60 ]; then ICON="σΑ²Ä";
    elif [ "$cap" -ge 50 ]; then ICON="σΑ¹Ω";
    elif [ "$cap" -ge 40 ]; then ICON="σΑ¹Ψ";
    elif [ "$cap" -ge 30 ]; then ICON="σΑ¹Ϋ";
    elif [ "$cap" -ge 20 ]; then ICON="σΑ¹Φ";
    elif [ "$cap" -ge 10 ]; then ICON="σΑ¹Μ";
    else ICON="σΑ²É"; fi
fi

echo "$ICON $cap%"
