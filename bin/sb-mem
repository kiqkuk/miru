#!/bin/bash
# miru: sb-mem | kiqkuk

while read -r name value unit; do
    case "$name" in
        MemTotal:) total=$value ;;
        MemAvailable:) avail=$value ;;
    esac
done < /proc/meminfo

used_gib_x10=$(( (total - avail) * 10 / 1048576 ))
main=$(( used_gib_x10 / 10 ))
rest=$(( used_gib_x10 % 10 ))

echo " ${main}.${rest}G"
