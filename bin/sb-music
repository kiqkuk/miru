#!/bin/bash
# miru: sb-music | kiqkuk

STATUS=$(playerctl status 2>/dev/null)
TITLE=$(playerctl metadata title 2>/dev/null)
ARTIST=$(playerctl metadata artist 2>/dev/null)

[ -z "$STATUS" ] && exit 0

if [ -n "$ARTIST" ]; then
    FULL_TEXT="$ARTIST - $TITLE"
else
    FULL_TEXT="$TITLE"
fi

WIDTH=40
ICON="󰎈"
TEXT="$FULL_TEXT   "
LENGTH=${#TEXT}

if [ "${#FULL_TEXT}" -le "$WIDTH" ]; then
    DISPLAY_TEXT="$FULL_TEXT"
else
    NOW=$(date +%s)
    OFFSET=$(( NOW % LENGTH ))
    
    CHUNK="${TEXT:$OFFSET}"
    DISPLAY_TEXT="${CHUNK}${TEXT:0:$OFFSET}"
    DISPLAY_TEXT="${DISPLAY_TEXT:0:$WIDTH}"
fi

echo "$ICON $DISPLAY_TEXT"
