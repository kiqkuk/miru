#!/bin/bash

PLAYERS="mpv,chromium,qutebrowser"

if ! pgrep -f "mpv|chromium|qutebrowser" > /dev/null; then
    exit 0
fi

STATUS=$(playerctl --player=$PLAYERS status 2>/dev/null)
TITLE=$(playerctl --player=$PLAYERS metadata title 2>/dev/null)
ARTIST=$(playerctl --player=$PLAYERS metadata artist 2>/dev/null)

[ -z "$STATUS" ] && exit 0

if [ -n "$ARTIST" ]; then
    FULL_TEXT="$ARTIST - $TITLE"
else
    FULL_TEXT="$TITLE"
fi

WIDTH=40
ICON="󰎈"
TEXT="$FULL_TEXT   "
LENGTH=${#TEXT}

if [ "$FULL_TEXT" -le "$WIDTH" ]; then
    DISPLAY_TEXT="$FULL_TEXT"
else
    NOW=$(date +%s)
    OFFSET=$(( NOW % LENGTH ))
    
    CHUNK="${TEXT:$OFFSET}"
    DISPLAY_TEXT="${CHUNK}${TEXT:0:$OFFSET}"
    DISPLAY_TEXT="${DISPLAY_TEXT:0:$WIDTH}"
fi

echo "$ICON $DISPLAY_TEXT" | rg -o '.*'
