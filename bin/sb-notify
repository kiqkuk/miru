#!/bin/bash
# miru: sb-notify | kiqkuk

NOTIF_FILE="${XDG_RUNTIME_DIR:-/tmp}/notify"
TIME_FILE="${XDG_RUNTIME_DIR:-/tmp}/notify_time"

if [ ! -s "$NOTIF_FILE" ]; then
  exit 0
fi

read -r NOTIF < "$NOTIF_FILE"
[ -z "$NOTIF" ] && exit 0

LIMIT=40
ICON="󰂚"
LENGTH="${#NOTIF}"

if [ "$LENGTH" -le $LIMIT ]; then
  echo "$ICON $NOTIF"
  exit 0
fi

NOW=$(date +%s)
if [ -f "$TIME_FILE" ]; then
  read -r START < "$TIME_FILE"
else
  START=$NOW
fi

ELAPSED=$(( NOW - START ))
PAGES=$(( (LENGTH + LIMIT -1) / LIMIT ))
CURRENT_PAGE=$(( (ELAPSED / 2) % PAGES ))
START_IDX=$(( CURRENT_PAGE * LIMIT ))
DISPLAY_TEXT="${NOTIF:$START_IDX:$LIMIT}"

echo "$ICON $DISPLAY_TEXT"
