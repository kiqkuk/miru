#!/bin/bash
# miru: sb-vol | kiqkuk

status=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
[ $? -ne 0 ] && echo "¾░Øƒ No Sink" && exit 0

vol_raw=$(echo "$status" | sed 's/Volume: //; s/ .*//')

if [[ "$vol_raw" == "1.00" ]]; then
    vol_perc=100
else
    vol_perc=$((10#${vol_raw#0.}))
fi

if [[ "$status" == *"[MUTED]"* ]]; then
  echo "¾░Øƒ Mute"
else
  if [ "$vol_perc" -eq 0 ]; then
    ICON="¾░Øƒ"
  elif [ "$vol_perc" -lt 40 ]; then
    ICON="¾░ò┐"
  elif [ "$vol_perc" -lt 70 ]; then
    ICON="¾░ûÇ"
  else
    ICON="¾░ò¥"
  fi
  
  echo "$ICON ${vol_perc}%"
fi
