#!/bin/bash
# miru: tui-menu | kiqkuk

LIST="$HOME/.local/share/miru/data/apps.list"
[ ! -f "$LIST" ] && touch "$LIST"

out=$(fzf \
    --reverse \
    --no-info \
    --no-scrollbar \
    --print-query \
    --delimiter=" | " \
    --with-nth=1 \
    --prompt="󰘳 Run: " \
    --header="CTRL-H: All Binaries" \
    --expect="ctrl-h" < "$LIST");

[ -z "$out" ] && exit 0

mapfile -t res <<< "$out"
query="${res[0]}"
key="${res[1]}"
sel="${res[2]}"

if [ "$key" == "ctrl-h" ]; then
  out_all=$(compgen -c | sort -u | fzf \
    --reverse \
    --no-scrollbar \
    --query="$query" \
    --print-query \
    --prompt="󰒲 All: ")

  [ -z "$out_all" ] && exit 0

  mapfile -t res_all <<< "$out_all"
  final_cmd="${res_all[1]:-${res_all[0]}}"
else
  if [ -n "$sel" ]; then
    final_cmd=$(echo "$sel" | cut -d'|' -f2 | xargs)
  else
    final_cmd="$query"
  fi
fi

[ -n "$final_cmd" ] && setsid --fork sh -c "$final_cmd" >/dev/null 2>&1
