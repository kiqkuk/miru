#!/bin/bash
# miru: tui-music | kiqkuk

query=$(fzf --reverse --print-query --no-info --prompt="箚럥 Search: " </dev/null | head -1)
[ -z "$query" ] && exit 0

printf "\rSearching $query..."
results=$(yt-dlp --quiet --flat-playlist \
        --print "%(title)s -- %(id)s" \
        "ytsearch10:$query")
[ -z "$results" ] && { echo "Not found"; exit 0; }

selected=$(echo "$results" | fzf --reverse --no-info --prompt="箚씂 Play: ")
[ -z "$selected" ] && exit 0

v_id="${selected##* -- }"
URL="https://www.youtube.com/watch?v=$v_id&list=RD$v_id"

printf "\rPlaying $selected..."
mpv --no-video \
    --term-playing-msg='${media-title}' \
    --ytdl-raw-options="cookies-from-browser=chromium,yes-playlist=,lazy-playlist=" \
    "$URL"
