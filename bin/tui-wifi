#!/bin/bash
# miru: tui-wifi | kiqkuk

INTERFACE="wlan0"

printf "\rScanning..."
iwctl station $INTERFACE scan &>/dev/null
sleep 1
WIFI_LIST="iwctl station $INTERFACE get-networks | sed 's/\x1b\[[0-9;]*m//g' | grep -E 'psk|open|8021x' | cut -c 5-32 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'"

SELECTED_SSID=$(fzf \
  --prompt="󰖩 Select WiFi: " \
  --reverse \
  --no-info \
  --bind "start:reload($WIFI_LIST)"
)

[ -z "$SELECTED_SSID" ] && exit 0

echo "Connecting to $SELECTED_SSID..."

iwctl station "$INTERFACE" connect "$SELECTED_SSID"
