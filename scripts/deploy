#!/bin/bash

SCRIPT_PATH=$(realpath "$0")
DOTS_DIR=$(dirname "$(dirname "$SCRIPT_PATH")")
USER_DIR="$DOTS_DIR/user"
SCRIPTS_SRC="$DOTS_DIR/scripts"
BIN_TARGET="$HOME/.local/bin"

[[ ! -d "$USER_DIR" ]] && { echo "ERROR: user folder not found"; exit 1; }

echo "Checking for broken links..."
fd -t l -H --max-depth 2 . "$HOME/.config" "$BIN_TARGET" 2>/dev/null | while read -r link; do
  [[ ! -e "$link" ]] && rm -v "$link"
done

if [[ -d "$USER_DIR" ]]; then
  echo "Checking user config..."
  fd -t f -H . "$USER_DIR" | while read -r DOT_FILE; do
    REL_FILE="${DOT_FILE#$USER_DIR/}"
    TARGET_FILE="$HOME/.config/$REL_FILE"
    [[ -e "$TARGET_FILE" || -L "$TARGET_FILE" ]] && continue
    mkdir -p "$(dirname "$TARGET_FILE")"
    ln -sfv "$DOT_FILE" "$TARGET_FILE"
  done
fi

if [[ -d "$SCRIPTS_SRC" ]]; then
  echo "Checking scripts on $BIN_TARGET..."
  mkdir -p "$BIN_TARGET"
  fd -t f . "$SCRIPTS_SRC" -E "deploy" | while read -r SCRIPT; do
    NAME=$(basename "$SCRIPT")
    TARGET_BIN="$BIN_TARGET/$NAME"
    [[ -e "$TARGET_BIN" || -L "$TARGET_BIN" ]] && continue
    chmod +x "$SCRIPT"
    ln -sfv "$SCRIPT" "$TARGET_BIN"
  done
fi

if [[ -d "/etc/zsh" ]]; then
  ZSHENV="/etc/zsh/zshenv"
  Z_CONF="export ZDOTDIR=\"\$HOME/.config/zsh\""
  echo "Checking $ZSHENV"
  if ! rg -q "ZDOTDIR" "$ZSHENV" 2>/dev/null; then
    echo "Adding ZDOTDIR to $ZSHENV..."
    echo "$Z_CONF" | sudo tee -a "$ZSHENV" > /dev/null
  fi
fi

echo "done"
