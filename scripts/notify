#!/bin/bash

MESSAGE="$1"
DURATION=${2:-6}
NOTIF_FILE="${XDG_RUNTIME_DIR:-/tmp}/notify"
TIME_FILE="${XDG_RUNTIME_DIR:-/tmp}/notify_time"

START_TIME=$(date +%s)
echo "$MESSAGE" > "$NOTIF_FILE"
echo "$START_TIME" > "$TIME_FILE"

pkill -RTMIN+13 someblocks
sleep "$DURATION"

CURRENT_IN_FILE=$(cat "$TIME_FILE" 2>/dev/null)

if [ "$START_TIME" = "$CURRENT_IN_FILE" ]; then
  truncate -s 0 "$NOTIF_FILE"
  pkill -RTMIN+13 someblocks
fi
