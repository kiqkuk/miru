#!/bin/bash

status=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)

if [ $? -ne 0 ]; then
	echo "¾░Øƒ No Sink"
  exit 0
fi

vol_raw=$(echo "$status" | rg -oP '0\.\d+')
vol_clean=${vol_raw#0.}
vol_perc=$((10#${vol_clean:-0}))

if [[ "$status" == *"[MUTED]"* ]]; then
  echo "¾░Øƒ Mute"
else
  if [ "$vol_perc" -eq 0 ]; then ICON="¾░Øƒ";
  elif [ "$vol_perc" -lt 40 ]; then ICON="¾░ò┐";
  elif [ "$vol_perc" -lt 70 ]; then ICON="¾░ûÇ";
  else ICON="¾░ò¥"; fi
    
  echo "$ICON ${vol_perc}%"
fi
